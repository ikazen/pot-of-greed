  <조문>
    <조문단위>
      <조문번호>14</조문번호>
      <조문여부>조문</조문여부>
      <조문제목>과세표준의 계산</조문제목>
      <조문내용>제14조(과세표준의 계산) 거주자의 종합소득에 대한 과세표준은 종합소득금액에서 종합소득공제를 적용한 금액으로 한다. 종합소득금액은 이자소득·배당소득·사업소득·근로소득·연금소득·기타소득의 합계액으로 한다.</조문내용>
      <시행일자>20100101</시행일자>
      <항>
        <항번호>1</항번호>
        <항내용>거주자의 종합소득에 대한 과세표준은 다음 각 호의 소득의 합계액으로 한다.</항내용>
        <호>
          <호번호>1</호번호>
          <호내용>이자소득금액</호내용>
        </호>
        <호>
          <호번호>2</호번호>
          <호내용>배당소득금액</호내용>
        </호>
        <호>
          <호번호>3</호번호>
          <호내용>사업소득금액</호내용>
        </호>
        <호>
          <호번호>4</호번호>
          <호내용>근로소득금액</호내용>
        </호>
        <호>
          <호번호>5</호번호>
          <호내용>연금소득금액</호내용>
        </호>
        <호>
          <호번호>6</호번호>
          <호내용>기타소득금액</호내용>
        </호>
      </항>
      <항>
        <항번호>2</항번호>
        <항내용>제1항에 따른 소득의 금액은 각각 제16조, 제17조, 제19조, 제20조, 제20조의3, 제21조에 따른 금액으로 한다.</항내용>
      </항>
    </조문단위>
    <조문단위>
      <조문번호>55</조문번호>
      <조문여부>조문</조문여부>
      <조문제목>세율</조문제목>
      <조문내용>제55조(세율) 거주자의 종합소득에 대한 소득세는 해당 연도의 종합소득과세표준에 다음의 세율을 적용하여 계산한 금액(이하 "종합소득산출세액"이라 한다)을 그 세액으로 한다.</조문내용>
      <시행일자>20230101</시행일자>
      <항>
        <항번호>1</항번호>
        <항내용>종합소득과세표준에 다음 각 호의 세율을 적용한다.</항내용>
        <호>
          <호번호>1</호번호>
          <호내용>1,400만원 이하: 100분의 6</호내용>
        </호>
        <호>
          <호번호>2</호번호>
          <호내용>1,400만원 초과 5,000만원 이하: 84만원 + 1,400만원 초과 금액의 100분의 15</호내용>
        </호>
        <호>
          <호번호>3</호번호>
          <호내용>5,000만원 초과 8,800만원 이하: 624만원 + 5,000만원 초과 금액의 100분의 24</호내용>
        </호>
      </항>
    </조문단위>
