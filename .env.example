# PostgreSQL (pgvector)
PG_DSN=postgresql://potofgreed:<password>@<OPS_TAILNET_IP>:5432/potofgreed

# Neo4j
NEO4J_URI=bolt://<OPS_TAILNET_IP>:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<password>

# Ollama (mac-server, 임베딩 + 리랭커)
OLLAMA_BASE_URL=http://<MAC_SERVER_IP>:11434

# Ollama Cloud (LLM 추론)
OLLAMA_CLOUD_URL=https://<ollama-cloud-host>
OLLAMA_CLOUD_API_KEY=<key>

# JWT
JWT_SECRET=<generate-with-openssl-rand-hex-32>
JWT_EXPIRE_MIN=1440

# 고정 계정 (username:bcrypt_hash 형식, 콤마 구분)
# 생성: python -c "from passlib.hash import bcrypt; print('user:' + bcrypt.hash('password'))"
AUTH_USERS=admin:<bcrypt-hash>
