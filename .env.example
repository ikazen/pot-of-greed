# PostgreSQL (pgvector)
# ops-vm(nexus network): postgres:5432 / local dev: <OPS_TAILNET_IP>:5432
PG_DSN=postgresql://potofgreed:<password>@postgres:5432/potofgreed

# Neo4j
# ops-vm(nexus network): neo4j:7687 / local dev: <OPS_TAILNET_IP>:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<password>

# Ollama (mac-server, 임베딩 + 리랭커)
OLLAMA_BASE_URL=http://<MAC_SERVER_IP>:11434

# LLM provider ("gemini" | "ollama")
LLM_PROVIDER=gemini
GEMINI_API_KEY=<google-ai-studio-key>
GEMINI_MODEL=gemini-2.5-flash

# Ollama Cloud (LLM_PROVIDER=ollama 시 사용)
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_API_KEY=<key>

# JWT
JWT_SECRET=<generate-with-openssl-rand-hex-32>
JWT_EXPIRE_MIN=1440

# 고정 계정 (username:bcrypt_hash 형식, 콤마 구분)
# 생성: python -c "from passlib.hash import bcrypt; print('user:' + bcrypt.hash('password'))"
AUTH_USERS=admin:<bcrypt-hash>

# Chainlit UI (ui 컨테이너 세션 서명용)
CHAINLIT_AUTH_SECRET=<generate-with-openssl-rand-hex-32>

# Chainlit 대화 영속화 (UI 컨테이너 → potofgreed DB, +asyncpg 필수)
CHAINLIT_DB_DSN=postgresql+asyncpg://potofgreed:<password>@postgres:5432/potofgreed

# RARR 역할별 모델 (결정 N) — 기본값으로 동작, 변경 필요 시만 설정
# RARR_DRAFT_MODEL=gemini-2.5-flash
# RARR_EDIT_MODEL=gemini-2.5-flash
# RARR_REASON_MODEL=gemini-2.5-flash
# RARR_AUX_PROVIDER=ollama
# RARR_AUX_MODEL=glm-5.2
# RARR 튜닝 노브 (0 = 무제한; 지연 단축 시 조정)
# RARR_MAX_CLAIMS=0
# RARR_QUESTIONS_PER_CLAIM=0

# 법제처 OPEN API (open.law.go.kr 신청 ID)
LAW_API_OC=
